{
  "name": "gentle-memories",
  "version": "1.0.0",
  "description": "Rediscover old journal notes inside the current vault.",
  "main": "main.js",
  "scripts": {
    "build": "tsc --noEmit && node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "serve:smoke": "node scripts/smoke-server.mjs",
    "test:unit": "node scripts/unit-test.mjs",
    "test:harness": "node scripts/harness-test.mjs",
    "test:contract": "node scripts/contract-test.mjs",
    "smoke": "npm run test:harness",
    "verify:manual-plan": "node scripts/verify-manual-plan.mjs",
    "verify:test-plan": "node scripts/verify-test-plan.mjs"
  },
  "keywords": [
    "obsidian",
    "plugin"
  ],
  "author": "Armstrong Yan",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.12.12",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.21.5",
    "obsidian": "^1.5.12",
    "typescript": "^5.4.5"
  }
}
